# ---------------------------------------------------------------------------
# Backend environment variables (FastAPI)
#
# Everything here is SERVER-SIDE ONLY. None of it reaches the browser.
# Never copy any of these into a REACT_APP_* variable — those are inlined into
# the public JS bundle at build time.
#
# Copy to .env and fill in.
# ---------------------------------------------------------------------------

# --- Database ---
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
DB_NAME=Hireflow

# --- Sessions ---
# Signs the app's own JWTs. Any long random string (30+ chars).
JWT_SECRET=

# --- AI (Groq) ---
# NOTE the spelling: GROQ (GroqCloud), not GROK (x.ai). They are different
# companies. ai_service.py reads GROQ_API_KEY at import time, so a wrong or
# missing name crashes the whole API on startup, not just the AI endpoints.
GROQ_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

# --- CORS ---
# Comma-separated. Do not leave this as "*" while allow_credentials is on —
# browsers reject that combination.
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Admin allowlist
#
# The ONLY way to become a platform admin. Cannot be requested at signup or
# set through the API.
#
# backend/admin.credentials.json is git-ignored, so it does NOT exist on
# hosted deploys — set these there instead. Both sources are merged.
# Leave both empty and nobody is an admin (fails closed).
# ---------------------------------------------------------------------------
ADMIN_EMAILS=
ADMIN_FIREBASE_UIDS=

# ---------------------------------------------------------------------------
# Firebase
#
# Only the project id is needed. ID tokens are verified against Google's
# public JWKS, so there is no service-account key to provision or store.
# Must match REACT_APP_FIREBASE_PROJECT_ID on the frontend.
# Leave empty to disable Firebase sign-in and fall back to password login.
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Outbound email (feedback / support)
#
# Plain SMTP — works with Gmail app passwords, Resend, Brevo, Mailgun, SES
# SMTP, or anything else. Leave SMTP_HOST empty to disable sending; feedback
# is still captured in the database and shown in the admin panel.
#
# SMTP_FROM must be an address the SMTP account is authorised to send as,
# otherwise SPF/DKIM fail and mail is filed as spam. The submitter's address
# is used as Reply-To, never as From.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=HireFlow
# "true" for implicit SSL on port 465; otherwise STARTTLS on 587 is used.
SMTP_USE_SSL=

# Where feedback is delivered.
FEEDBACK_TO=connecting800@gmail.com
