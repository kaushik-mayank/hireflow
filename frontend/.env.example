# ---------------------------------------------------------------------------
# Frontend environment variables (Create React App + CRACO)
#
# IMPORTANT: this project is CRA, not Vite. Variables are read as
# `process.env.REACT_APP_*` and are INLINED AT BUILD TIME. They must be set on
# the Render frontend service BEFORE the build runs — they are not read at
# runtime, and changing them requires a rebuild.
#
# Anything prefixed REACT_APP_ ends up in the public JS bundle. That is fine
# for the values below (Firebase web config is public by design) but means no
# server secret may ever be put here. The admin allowlist in particular is
# backend-only — see backend/admin.credentials.example.json.
#
# Copy to .env and fill in.
# ---------------------------------------------------------------------------

# Where the FastAPI backend is reachable.
REACT_APP_BACKEND_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Firebase Authentication
#
# From Firebase console > Project settings > Your apps > Web app > SDK setup.
#
# If these are omitted the app still works: sign-in falls back to the legacy
# password endpoints, and the Forgot Password page explains that resets are
# unavailable. That is what makes local development possible without a
# Firebase project.
# ---------------------------------------------------------------------------
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Optional. Only needed if you want Firebase Analytics; it is loaded lazily and
# never blocks sign-in.
REACT_APP_FIREBASE_MEASUREMENT_ID=
